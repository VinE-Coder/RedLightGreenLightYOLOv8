def draw_label(img, text, pos, text_color):
    font = cv2.FONT_HERSHEY_SIMPLEX
    font_scale = 0.7
    thickness = 2
    text_size = cv2.getTextSize(text, font, font_scale, thickness)[0]

    # Draw background
    cv2.rectangle(img, pos, (pos[0] + text_size[0] + 10, pos[1] - text_size[1] - 10), (0, 0, 0), -1)
    # Draw text
    cv2.putText(img, text, (pos[0] + 5, pos[1] - 5), font, font_scale, text_color, thickness)

def process_video(input_path, output_path):
    if not os.path.exists(input_path):
        print(f"❌ Error: Input file {input_path} not found!")
        return

    cap = cv2.VideoCapture(input_path)
    frame_width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    frame_height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    fps = cap.get(cv2.CAP_PROP_FPS)

    # Set up output writer
    fourcc = cv2.VideoWriter_fourcc(*'mp4v')
    out = cv2.VideoWriter(output_path, fourcc, fps, (frame_width, frame_height))

    print("🚦 Processing video... press 'q' to stop early.\n")

    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break

        pil_image = Image.fromarray(cv2.cvtColor(frame, cv2.COLOR_BGR2RGB))
        
        # Detect traffic lights
        detection = model.detect(pil_image, 'traffic light')

        for obj in detection["objects"]:
            x1 = int(obj["x_min"] * frame.shape[1])
            y1 = int(obj["y_min"] * frame.shape[0])
            x2 = int(obj["x_max"] * frame.shape[1])
            y2 = int(obj["y_max"] * frame.shape[0])

            # Crop and analyze color
            tl_roi = pil_image.crop((x1, y1, x2, y2))
            encoded_roi = model.encode_image(tl_roi)
            color_response = model.query(encoded_roi, 
                "What color is this traffic light? Answer only: red, yellow, or green."
            )["answer"].lower()

            # Color mapping
            color_map = {
                'red': (0, 0, 255),
                'green': (0, 255, 0),
                'yellow': (0, 255, 255)
            }
            light_color = color_map.get(color_response, (255, 255, 255))

            # Draw on frame
            cv2.rectangle(frame, (x1, y1), (x2, y2), light_color, 2)
            draw_label(frame, color_response.upper(), (x1, y1 - 10), light_color)

        # Write and show frame
        out.write(frame)
        cv2.imshow('Traffic Light Detection', frame)

        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

    cap.release()
    out.release()
    cv2.destroyAllWindows()
    print(f"✅ Processing complete! Output saved to {output_path}")

# Run immediately
process_video(input_path, output_path)
