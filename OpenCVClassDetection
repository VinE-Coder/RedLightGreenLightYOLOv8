import cv2
from ultralytics import YOLO

# Define class labels for traffic lights
class_names = ['red', 'green', 'yellow']

# Load the YOLO model
model = YOLO('yolov8n.pt')  # Replace 'best.pt' with the path to your trained model file

# Initialize webcam
cap = cv2.VideoCapture(0)

if not cap.isOpened():
    print("Error: Could not open webcam.")
    exit()

while True:
    # Capture frame-by-frame
    ret, frame = cap.read()

    if not ret:
        print("Error: Could not read frame.")
        break

    # Run YOLO model on the frame
    results = model.predict(source=frame)

    # Draw bounding boxes and labels on the frame
    for result in results:
        for box in result.boxes:
            x1, y1, x2, y2 = box.xyxy[0].int().tolist()
            cls = int(box.cls[0])  # Class ID (converted to int)
            conf = float(box.conf[0])  # Confidence (converted to float)

            # Ensure the class ID is within range
            if cls < len(class_names):
                label = f'{class_names[cls]} {conf:.2f}'  # Class label and confidence
                cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)  # Green bounding box
                cv2.putText(frame, label, (x1, y1 - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)
            else:
                print(f"Warning: Class ID {cls} is out of range for class names.")

    # Display the resulting frame
    cv2.imshow('YOLO Webcam', frame)

    # Press 'q' to exit the loop
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

# Release the capture and close windows
cap.release()
cv2.destroyAllWindows()
